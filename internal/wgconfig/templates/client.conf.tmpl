[Interface]
Address = {{ .ClientAddress }}
MTU = 1420
PrivateKey = {{ .ClientPrivateKey }}
DNS = 1.1.1.1, 1.0.0.1

[Peer]
PublicKey = {{ .ServerPublicKey }}
Endpoint = {{ .ServerEndpoint }}:{{ .Port }}
# Server provisioning currently configures IPv4 forwarding/NAT only.
# Keep tunnel routing IPv4-only unless server-side IPv6 is explicitly configured.
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
